# Environment configuration
# Possible values: development, test, production
NODE_ENV=development

# Server port
PORT=3000

# Database connection string
# Format depends on the database type:
# PostgreSQL: postgresql://username:password@localhost:5432/database_name
# SQLite: sqlite://./dev.sqlite3
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/torn_dashboard

# Secret key for JWT token generation and validation
# Should be a long, random string in production
JWT_SECRET=your_jwt_secret_key_here

# Torn API key for accessing the Torn game API
# Get your API key from https://www.torn.com/preferences.php#tab=api
TORN_API_KEY=your_torn_api_key_here

# Allowed origins for CORS
# Comma-separated list of domains, or use * for development
CORS_ORIGIN=http://localhost:3001

