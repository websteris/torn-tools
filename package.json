{
  "name": "torn-dashboard",
  "version": "0.1.0",
  "description": "A modular dashboard for the Torn game with integrated tools and scripts",
  "scripts": {
    "start": "node server/server.js",
    "dev": "cd server && npm run dev",
    "test": "cd server && npm run test",
    "test:coverage": "cd server && npm run test -- --coverage --coverageReporters=text --coverageReporters=lcov",
    "init-db": "node server/scripts/init-db.js",
    "install-all": "npm install && cd server && npm install",
    "client-install": "cd client && npm install",
    "client-build": "cd client && npm run build",
    "client-dev": "cd client && npm run dev"
  },
  "keywords": [
    "torn",
    "dashboard",
    "api",
    "game"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "sqlite3": "^5.1.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  }
}
