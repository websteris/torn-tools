{
  "name": "torn-dashboard-server",
  "version": "0.1.0",
  "description": "Backend server for Torn Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --updateSnapshot --watchAll=false --ci --reporter=\"default\"",
    "test:api": "jest --testPathPattern=integration --updateSnapshot --watchAll=false",
    "test:noapi": "jest --testPathIgnorePatterns=integration --updateSnapshot --watchAll=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "sqlite3": "^5.1.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  }
}
